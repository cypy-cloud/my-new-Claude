# ============================================
# FP AI Assistant - 환경변수 설정 예시
# .env.local.example을 복사해서 .env.local로 사용하세요
# ============================================

# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Provider (필수)
# 'mock' = API 키 없이 개발 가능 (기본값)
# 'anthropic' = Claude API 사용
# 'openai' = OpenAI GPT 사용
AI_PROVIDER=mock
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# App (필수)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FP AI Assistant

# Payment (Phase 2에서 연동)
# TOSS_PAYMENTS_CLIENT_KEY=test_ck_your_key
# TOSS_PAYMENTS_SECRET_KEY=test_sk_your_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_SECRET_KEY=sk_test_your_key

# Storage (Phase 3에서 연동)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=fp-ai-documents
