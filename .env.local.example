# ============================================
# FP AI Assistant - 환경변수 설정 예시
# .env.local.example을 복사해서 .env.local로 사용하세요
# ============================================

# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Provider (필수)
# 기본 Provider: 'mock' | 'anthropic' | 'openai' | 'gemini'
AI_PROVIDER=mock

# 기능별 Provider 개별 지정 (선택 — 미설정 시 AI_PROVIDER 사용)
# AI_PROVIDER_SMS=anthropic
# AI_PROVIDER_SCRIPT=anthropic
# AI_PROVIDER_DOCUMENT=openai

# API Keys (사용할 Provider에 맞는 키만 설정)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
# GEMINI_API_KEY=your_gemini_api_key

# App (필수)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FP AI Assistant

# Payment (Phase 2에서 연동)
# TOSS_PAYMENTS_CLIENT_KEY=test_ck_your_key
# TOSS_PAYMENTS_SECRET_KEY=test_sk_your_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_SECRET_KEY=sk_test_your_key

# Storage (Phase 3에서 연동)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=fp-ai-documents

# Cron (원본 PDF 자동 삭제 스케줄러 인증 — 운영 환경 필수)
# Vercel Cron이 이 값을 Authorization: Bearer 헤더로 자동 전송합니다.
CRON_SECRET=your_random_secret_string
